{
  "name": "@odds-and-endpoints/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "dev:cloudflare": "pnpm --filter=api build && pnpm run build && wrangler dev -c wrangler.jsonc -c ../api/wrangler.toml",
    "preview:wrangler": "pnpm build && pnpm dlx wrangler dev -c wrangler.jsonc -c ../api/wrangler.toml",
    "postinstall": "nuxt prepare"
  },
  "onlyBuiltDependencies": [
    "better-sqlite3",
    "sharp"
  ],
  "dependencies": {
    "@number-flow/vue": "^0.4.8",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/seo": "5.1.3",
    "@nuxtjs/sitemap": ">=7.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@takumi-rs/core": "^1.1.2",
    "@takumi-rs/wasm": "^1.1.2",
    "eslint": "^9.39.0",
    "nuxt": "^4.4.4",
    "nuxt-ai-ready": "1.3.2",
    "satori": "^0.26.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@nuxt/schema": "^4.4.4",
    "@odds-and-endpoints/types": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "h3": "^1.15.11",
    "nitropack": "^2.13.4",
    "tailwindcss": "^3.4.0",
    "wrangler": "4.23.0"
  }
}
